                <property
                  dataType="System.String"
                  description="The SQL command to be executed."
                  name="SqlCommand"
                  UITypeEditor="Microsoft.DataTransformationServices.Controls.ModalMultilineStringEditor">select sod.LineTotal as TotalLinea,
sod.UnitPriceDiscount as Descuento,
sod.UnitPrice as PrecioUnitario,
sod.OrderQty as Cantidad,
sod.ProductID as ProductID,
soh.SalesOrderNumber as NumeroOrden,
soh.TerritoryID,
soh.CustomerID,
isnull(soh.SalesPersonID,0) As SalesPersonID,
sod.SpecialOfferID,
soh.OrderDate,
soh.DueDate,
soh.ShipDate
from sales.SalesOrderHeader soh
left outer join sales.SalesOrderDetail sod
on soh.SalesOrderID=sod.SalesOrderID</property>
                <property
