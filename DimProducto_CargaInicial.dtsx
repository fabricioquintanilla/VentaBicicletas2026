              refId="Package\Llenar DimProducto\OLE DB Source"
              componentClassID="Microsoft.OLEDBSource"
              contactInfo="OLE DB Source;Microsoft Corporation; Microsoft SQL Server; (C) Microsoft Corporation; All Rights Reserved; http://www.microsoft.com/sql/support;7"
              description="OLE DB Source"
              name="OLE DB Source"
              usesDispositions="true"
              version="7">
              <properties>
                <property
                  dataType="System.Int32"
                  description="The number of seconds before a command times out.  A value of 0 indicates an infinite time-out."
                  name="CommandTimeout">0</property>
                <property
                  dataType="System.String"
                  description="Specifies the name of the database object used to open a rowset."
                  name="OpenRowset"></property>
                <property
                  dataType="System.String"
                  description="Specifies the variable that contains the name of the database object used to open a rowset."
                  name="OpenRowsetVariable"></property>
                <property
                  dataType="System.String"
                  description="The SQL command to be executed."
                  name="SqlCommand"
                  UITypeEditor="Microsoft.DataTransformationServices.Controls.ModalMultilineStringEditor">select p.ProductID as ProductoID,
p.Name as NombreProducto,
p.ProductNumber as NumeroProducto,
ISNULL(CONVERT(VARCHAR(50),p.Color),'Color No Definido') AS Color,
CASE WHEN ProductLine IS NULL THEN 'Linea No Definida' 
WHEN ProductLine='R' THEN 'Road'
WHEN ProductLine='M' THEN 'Mountain'
WHEN ProductLine='T' THEN 'Touring'
WHEN ProductLine='S' THEN 'Standard' END as LineaProducto,
CASE WHEN Class IS NULL THEN 'Clase No Definida' 
WHEN Class='H' THEN 'High'
WHEN Class='M' THEN 'Medium'
WHEN Class='L' THEN 'Low' END as Clase,
CASE WHEN Style IS NULL THEN 'Estilo No Definido' 
WHEN Style='W' THEN 'Women'
WHEN Style='M' THEN 'Men'
WHEN Style='U' THEN 'Universal' END as Estilo,
p.ListPrice as PrecioLista,
ISNULL(pm.Name,'Modelo No Definido') as Modelo,
ISNULL(pc.Name,'Categoria No Definida') as Categoria,
ISNULL(ps.Name,'Subcategoria No Definida') as Subcategoria
from Production.Product p
left outer join Production.ProductModel pm
on p.ProductModelID=pm.ProductModelID
left outer join Production.ProductSubcategory ps
on ps.ProductSubcategoryID=p.ProductSubcategoryID
left outer join Production.ProductCategory pc
on ps.ProductCategoryID=pc.ProductCategoryID</property>
                <property
